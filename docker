FROM python:3.9-slim

WORKDIR /app

COPY requirements.txt .
RUN pip install --no-cache-dir -r requirements.txt

COPY app.py .

EXPOSE 5000

# Запуск от непривилегированного пользователя (безопасность)
RUN useradd -m -u 1000 appuser && chown -R appuser /app
USER appuser

CMD ["python", "app.py"]
